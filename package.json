{
  "name": "alien-index",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "node scripts/build.mjs",
    "start": "node scripts/start.mjs",
    "preview": "npm run build && npm start",
    "check:assets": "node scripts/check-assets.mjs",
    "typecheck": "tsc --noEmit",
    "firebase:build": "npm --prefix functions run build",
    "test:functions": "npm --prefix functions test",
    "test:rules": "firebase emulators:exec --project demo-alien-index --only firestore,storage \"vitest run tests/rules\"",
    "test:integration": "firebase emulators:exec --project demo-alien-index --only auth,firestore,storage,functions \"vitest run tests/integration\"",
    "test:firebase": "npm run firebase:build && npm run test:functions && npm run test:rules && npm run test:integration",
    "initialize:storage": "node scripts/initialize-firebase-storage.mjs",
    "ensure:service-identities": "node scripts/ensure-google-service-identities.mjs",
    "ensure:callable-invoker": "node scripts/ensure-callable-invoker.mjs",
    "verify:firebase": "node scripts/verify-firebase-production.mjs",
    "deploy:hosting": "firebase deploy --only hosting --project alien-index",
    "inspect:admin-config": "node functions/scripts/read-admin-config.mjs",
    "logs:function": "node scripts/read-function-logs.mjs",
    "logs:cloud-run": "node scripts/read-cloud-run-logs.mjs",
    "probe:create-scan": "node scripts/probe-production-create-scan.mjs",
    "deploy:create-scan": "npm run firebase:build && firebase deploy --only functions:createScan --project alien-index",
    "configure:firebase": "node scripts/configure-firebase-production.mjs",
    "configure:openai-secret": "node scripts/configure-openai-secret.mjs",
    "deploy:firebase": "npm run build && firebase deploy --project alien-index"
  },
  "dependencies": {
    "firebase": "^12.0.0",
    "next": "16.2.11",
    "react": "19.2.8",
    "react-dom": "19.2.8"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "firebase-tools": "^14.23.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "postcss": "8.5.21",
    "sharp": "0.35.3"
  }
}
