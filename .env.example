# 도메인 루트(/)에서 서비스할 때는 비워 둡니다.
# /alien-index 같은 하위 경로에서 서비스할 때만 값을 지정합니다.
NEXT_PUBLIC_BASE_PATH=

# Firebase 웹 앱 설정
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# App Check reCAPTCHA Enterprise 사이트 키. 등록 전에는 비워 monitor mode로 운영합니다.
NEXT_PUBLIC_FIREBASE_APP_CHECK_SITE_KEY=

# 로컬 Emulator Suite 사용 시에만 true로 설정합니다.
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=false
NEXT_PUBLIC_FIREBASE_APP_CHECK_DEBUG_TOKEN=false

# 서버 전용 OpenAI 키. NEXT_PUBLIC_ 접두사를 붙이지 않습니다.
# 배포 시 Firebase Functions Secret Manager로 복사합니다.
OPENAI_API_KEY=
